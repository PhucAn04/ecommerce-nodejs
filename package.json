{
  "name": "ecommerce-nodejs",
  "version": "1.0.0",
  "description": "nodejs ecommerce",
  "main": "dist/app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon",
